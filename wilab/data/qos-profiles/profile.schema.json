{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QoS Profile Catalogue",
  "description": "Array of QoS profiles for wi-lab network simulation",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "description", "mode", "steps"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1,
        "description": "Unique profile identifier"
      },
      "description": {
        "type": "string",
        "description": "Human-readable description of the profile scenario"
      },
      "mode": {
        "type": "string",
        "enum": ["loop", "bounce", "once", "once-hold-last"],
        "description": "Playback mode controlling step sequence execution"
      },
      "steps": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["duration_sec"],
          "additionalProperties": false,
          "properties": {
            "duration_sec": {
              "type": "integer",
              "minimum": 1,
              "description": "Duration of this step in seconds"
            },
            "quality": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Quality score 0-100 applied to both download and upload netem"
            },
            "dl_speed_kbit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000000,
              "description": "Download speed cap in kbit/s"
            },
            "ul_speed_kbit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000000,
              "description": "Upload speed cap in kbit/s"
            },
            "advanced": {
              "type": "object",
              "description": "Advanced netem override (mutually exclusive with quality)",
              "additionalProperties": false,
              "properties": {
                "packet_loss_percent": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "delay_ms": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 5000
                },
                "jitter_ms": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "corruption_percent": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 5
                },
                "delay_distribution": {
                  "type": "string",
                  "enum": ["normal", "pareto", "paretonormal"]
                }
              }
            }
          },
          "allOf": [
            {
              "not": {
                "required": ["quality", "advanced"]
              }
            },
            {
              "anyOf": [
                { "required": ["quality"] },
                { "required": ["dl_speed_kbit"] },
                { "required": ["ul_speed_kbit"] },
                { "required": ["advanced"] }
              ]
            }
          ]
        }
      }
    }
  }
}
